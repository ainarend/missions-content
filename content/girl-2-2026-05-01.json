u peal."},{"text":"💧 Mul on sinine vesi ja roheline maa."},{"text":"💫 Ma olen üks paljudest, kes Päikese ümber tiirleb."}],"options":[{"label":"Kuu","isCorrect":false},{"label":"Täht","isCorrect":false},{"label":"Maa","isCorrect":true}],"additionalData":{"backgroundColor":"0xFF8A2BE2","category":"cosmos","icon":"🌌"}}]}