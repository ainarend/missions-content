{"plant":[{"level":"1","type":"plant","question":"Mul on roheline värv ja ma hoian vihma kinni. Mis ma olen?","hints":[{"text":"🤔 Ma kasvan puu küljes."},{"text":"👀 Sa näed mind maapinnal sügisel."},{"text":"🌳 Ma olen puu osa."}],"options":[{"label":"Kivi","isCorrect":false},{"label":"Leht","isCorrect":true},{"label":"Lill","isCorrect":false}],"additionalData":{"backgroundColor":"0xFFF0E68C","category":"plant","icon":"🌱"}},{"level":"2","type":"plant","question":"Mul on palju värve ja ma lõhnan hästi. Mis ma olen?","hints":[{"text":"👃 Ma meeldin mesilastele."},{"text":"🌈 Võin olla punane, kollane või sinine."},{"text":"🪴 Kasvan peenras."}],"options":[{"label":"Lill","isCorrect":true},{"label":"Kõrv","isCorrect":false},{"label":"Puu","isCorrect":false}],"additionalData":{"backgroundColor":"0xFFDA70D6","category":"plant","icon":"🌱"}},{"level":"3","type":"plant","question":"Ma olen suur ja mul on palju lehti. Sa saad minu varjus mängida. Mis ma olen?","hints":[{"text":"🏡 Linnud ehitavad minu okstele pesi."},{"text":"🌬️ Minu oksad kõiguvad tuule käes."},{"text":"⬆️ Ma kasvan kõrgeks taeva poole."}],"options":[{"label":"Tool","isCorrect":false},{"label":"Maja","isCorrect":false},{"label":"Puu","isCorrect":true}],"additionalData":{"backgroundColor":"0xFF8FBC8F","category":"plant","icon":"🌱"}},{"level":"4","type":"plant","question":"Ma olen see, mida taimed joovad, et kasvada suureks. Mis ma olen?","hints":[{"text":"💧 Ilma minuta taimed kuivavad."},{"text":"🌧️ Ma tulen taevast alla vihmana."},{"text":"💦 Sa valad mind kannust taimedele."}],"options":[{"label":"Mahl","isCorrect":false},{"label":"Muru","isCorrect":false},{"label":"Vesi","isCorrect":true}],"additionalData":{"backgroundColor":"0xFF87CEEB","category":"plant","icon":"🌱"}},{"level":"5","type":"plant","question":"Ma olen väga pisike, aga minu seest kasvab välja suur taim. Mis ma olen?","hints":[{"text":"🤏 Sa võid mind mulda panna."},{"text":"🌱 Minust tuleb välja juur ja vars."},{"text":"🎁 Ma olen nagu tilluke kingitus, mis ootab avamist."}],"options":[{"label":"Kivi","isCorrect":false},{"label":"Seeme","isCorrect":true},{"label":"Muru","isCorrect":false}],"additionalData":{"backgroundColor":"0xFFBDB76B","category":"plant","icon":"🌱"}}]}