{"transport":[{"level":"1","type":"transport","question":"Mul on kaks ratast ja ma viin sind edasi, kui sa mind pedaalid. Kes ma olen?","hints":[{"text":"👀 Sa pead mind ise liikuma panema."},{"text":"🦵 Mul on pedaalid, mida sa jalgadega keerutad."},{"text":"👧 Sa saad minuga parki või sõprade juurde sõita."}],"options":[{"label":"Auto","isCorrect":false},{"label":"Jalgratas","isCorrect":true},{"label":"Laev","isCorrect":false}],"additionalData":{"backgroundColor":"0xFFADD8E6","category":"transport","icon":"🚦"}},{"level":"2","type":"transport","question":"Mul on neli ratast, mootor ja ma sõidan mööda teed. Minuga saab poodi või vanaema juurde. Mis ma olen?","hints":[{"text":"👨‍👩‍👧‍👦 Sinna sisse mahub terve perekond."},{"text":"🛣️ Ma sõidan asfaltteedel."},{"text":"⛽ Mulle meeldib bensiin või elekter."}],"options":[{"label":"Buss","isCorrect":false},{"label":"Auto","isCorrect":true},{"label":"Rong","isCorrect":false}],"additionalData":{"backgroundColor":"0xFF90EE90","category":"transport","icon":"🚦"}},{"level":"3","type":"transport","question":"Mul on suured tiivad, mul on mootorid ja ma viin sind pilvede kohale. Mis ma olen?","hints":[{"text":"☁️ Ma lendan väga kõrgel taevas."},{"text":"🌍 Minuga saab minna teistesse riikidesse."},{"text":"📢 Mu mootorid teevad suurt müra õhkutõusul."}],"options":[{"label":"Helikopter","isCorrect":false},{"label":"Lennuk","isCorrect":true},{"label":"Rakett","isCorrect":false}],"additionalData":{"backgroundColor":"0xFFB0C4DE","category":"transport","icon":"🚦"}},{"level":"4","type":"transport","question":"Ma olen väga pikk ja mul on palju vaguneid. Ma sõidan mööda raudteed ja teen \"tšuh-tšuh\" häält. Mis ma olen?","hints":[{"text":"🛤️ Ma liigun ainult spetsiaalsetel radadel."},{"text":"💨 Minu esiosas on vedur."},{"text":"👨‍👩‍👧‍👦 Ma mahutan korraga väga palju inimesi."}],"options":[{"label":"Trollibuss","isCorrect":false},{"label":"Rong","isCorrect":true},{"label":"Tramm","isCorrect":false}],"additionalData":{"backgroundColor":"0xFFDDA0DD","category":"transport","icon":"🚦"}},{"level":"5","type":"transport","question":"Mul ei ole rattaid, aga ma viin sind üle vee. Ma võin olla suur või väike. Mis ma olen?","hints":[{"text":"🌊 Ma ujun merel või järvel."},{"text":"⚓ Mul on ankur, et paigal püsida."},{"text":"🏝️ Minuga saab saartele reisida."}],"options":[{"label":"Allveelaev","isCorrect":false},{"label":"Laev","isCorrect":true},{"label":"Paat","isCorrect":false}],"additionalData":{"backgroundColor":"0xFFFFDAB9","category":"transport","icon":"🚦"}}],"food":[{"level":"1","type":"food","question":"Olen punane või roheline ja kasvan puu otsas. Mind on hea ampsata! Mis ma olen?","hints":[{"text":"🤔 Mõtle, mis on ümmargune ja mahlane."},{"text":"🌿 Olen tervislik valik."},{"text":"😋 Mind on hea vahepalaks süüa."}],"options":[{"label":"Banaan","isCorrect":false},{"label":"Õun","isCorrect":true},{"label":"Porgand","isCorrect":false}],"additionalData":{"backgroundColor":"0xFF800080","category":"food","icon":"🍽️"}},{"level":"2","type":"food","question":"Olen valge ja lehmad annavad mind. Lapsed armastavad mind juua! Mis ma olen?","hints":[{"text":"💭 Mõtle, mis on valge ja vedel."},{"text":"🐾 Mind saad loomalt."},{"text":"💪 Mind juues saad tugevaks."}],"options":[{"label":"Vesi","isCorrect":false},{"label":"Piim","isCorrect":true},{"label":"Limonaad","isCorrect":false}],"additionalData":{"backgroundColor":"0xFFADD8E6","category":"food","icon":"🍽️"}},{"level":"3","type":"food","question":"Mind küpsetatakse ahjus ja ma olen tihti söögilaua peal. Sa võid mind võiga süüa. Mis ma olen?","hints":[{"text":"🥐 Mõtle, mis on pagaritoode."},{"text":"🔥 Mind tehakse kuumas ahjus."},{"text":"🥪 Minuga saab teha võileiba."}],"options":[{"label":"Sai","isCorrect":false},{"label":"Leib","isCorrect":true},{"label":"Kook","isCorrect":false}],"additionalData":{"backgroundColor":"0xFFD2B48C","category":"food","icon":"🍽️"}},{"level":"4","type":"food","question":"Olen oranž ja mul on roheline tutike. Jänesed armastavad mind krõmpsutada. Kes ma olen?","hints":[{"text":"🌱 Mõtle, mis kasvab maa sees."},{"text":"🧡 Olen tavaliselt oranži värvi."},{"text":"👀 Mind süües saad head silmad."}],"options":[{"label":"Tomat","isCorrect":false},{"label":"Porgand","isCorrect":true},{"label":"Kartul","isCorrect":false}],"additionalData":{"backgroundColor":"0xFFFF7F50","category":"food","icon":"🍽️"}},{"level":"5","type":"food","question":"Olen kollane ja mõnikord on mul augud sees. Mind saad süüa võileiva peal või niisama. Mis ma olen?","hints":[{"text":"🥪 Mind pannakse tihti võileiva peale."},{"text":"⚙️ Mind tehakse piimast."},{"text":"😋 Mind saab riivida."}],"options":[{"label":"Muna","isCorrect":false},{"label":"Juust","isCorrect":true},{"label":"Või","isCorrect":false}],"additionalData":{"backgroundColor":"0xFFFFFF00","category":"food","icon":"🍽️"}}]}