{"animal":[{"level":"1","type":"animal","question":"Mul on pehmed käpad ja pikk saba. Mulle meeldib nurruda ja magada. Kes ma olen?","hints":[{"text":"👀 Mulle meeldib hiiri jahtida."},{"text":"🥛 Mulle meeldib piima juua."},{"text":"🧶 Mulle meeldib keraga mängida."}],"options":[{"label":"Koer","isCorrect":false},{"label":"Kass","isCorrect":true},{"label":"Part","isCorrect":false}],"additionalData":{"backgroundColor":"0xFFE0BBE4","category":"animal","icon":"🐾"}},{"level":"2","type":"animal","question":"Ma olen inimese parim sõber. Mulle meeldib saba liputada ja jalutada. Kes ma olen?","hints":[{"text":"🦴 Mulle meeldib luid närida."},{"text":"🗣️ Ma teen hundi moodi \"auh-auh!\"."},{"text":"🥎 Mulle meeldib palli tuua."}],"options":[{"label":"Rebane","isCorrect":false},{"label":"Koer","isCorrect":true},{"label":"Kass","isCorrect":false}],"additionalData":{"backgroundColor":"0xFF957DAD","category":"animal","icon":"🐾"}},{"level":"3","type":"animal","question":"Ma elan farmis ja mul on roosa nina. Mulle meeldib mudas möllata ja \"röh-röh\" teha. Kes ma olen?","hints":[{"text":"🌽 Mulle meeldib süüa maisi."},{"text":"🏠 Ma elan laudas."},{"text":"🚿 Pärast muda vajan ma pesu."}],"options":[{"label":"Lammas","isCorrect":false},{"label":"Siga","isCorrect":true},{"label":"Lehm","isCorrect":false}],"additionalData":{"backgroundColor":"0xFFA0D2DB","category":"animal","icon":"🐾"}},{"level":"4","type":"animal","question":"Ma elan savannis ja mul on suur lakk. Ma olen džungli kuningas ja teen \"mrr-mrr\" häält. Kes ma olen?","hints":[{"text":"🌍 Ma elan kuumades kohtades."},{"text":"🤔 Mõned inimesed kutsuvad mind \"suureks kassiks\"."},{"text":"👑 Mul on uhke karvane \"kroon\" ümber pea."}],"options":[{"label":"Tiiger","isCorrect":false},{"label":"Lõvi","isCorrect":true},{"label":"Hunt","isCorrect":false}],"additionalData":{"backgroundColor":"0xFFDA2C38","category":"animal","icon":"🐾"}},{"level":"5","type":"animal","question":"Ma olen suur ja hall, mul on pikad kõrvad ja pikk lont. Mulle meeldib veega pritsida. Kes ma olen?","hints":[{"text":"🍌 Mulle meeldib banaane süüa."},{"text":"🌳 Mul on suured jalad nagu puupalgid."},{"text":"👃 Mu nina on nii pikk, et see on nagu voolik."}],"options":[{"label":"Ninasarvik","isCorrect":false},{"label":"Elevant","isCorrect":true},{"label":"Jõehobu","isCorrect":false}],"additionalData":{"backgroundColor":"0xFF88B04B","category":"animal","icon":"🐾"}}]}