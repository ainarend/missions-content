{"animal":[{"level":"1","type":"animal","question":"Mul on kohev saba ja ma elan metsas. Mulle meeldib hiilida ja kanu püüda. Kes ma olen?","hints":[{"text":"🌳 Ma elan metsas ja mul on urg."},{"text":"🧡 Mu karv on sageli oranžikaspunane."},{"text":"🤫 Ma olen salakaval ja püüan hiiri."}],"options":[{"label":"Orav","isCorrect":false},{"label":"Rebane","isCorrect":true},{"label":"Jänes","isCorrect":false}],"additionalData":{"backgroundColor":"0xFF9370DB","category":"animal","icon":"🐾"}},{"level":"2","type":"animal","question":"Ma elan savannis ja mul on uhke lakk. Ma olen džungli kuningas ja teen valju möiret. Kes ma olen?","hints":[{"text":"☀️ Ma elan soojades kohtades."},{"text":"👑 Mõned ütlevad, et ma olen džungli kuningas."},{"text":"🔊 Minu hääl on väga valju."}],"options":[{"label":"Tiiger","isCorrect":false},{"label":"Lõvi","isCorrect":true},{"label":"Krokodill","isCorrect":false}],"additionalData":{"backgroundColor":"0xFF6495ED","category":"animal","icon":"🐾"}},{"level":"3","type":"animal","question":"Mul on pikad kõrvad ja lühike saba. Mulle meeldib porgandeid närida ja ma hüppan ringi. Kes ma olen?","hints":[{"text":"🥕 Mulle maitsevad porgandid ja kapsas."},{"text":"👂 Mul on pikad, püstised kõrvad."},{"text":"🤸 Ma liigun hüpeldes kiiresti edasi."}],"options":[{"label":"Orav","isCorrect":false},{"label":"Jänes","isCorrect":true},{"label":"Hiir","isCorrect":false}],"additionalData":{"backgroundColor":"0xFF8FBC8F","category":"animal","icon":"🐾"}},{"level":"4","type":"animal","question":"Ma magan talvel pikas unes. Mulle meeldib mesi ja ma olen suur ja karvane. Kes ma olen?","hints":[{"text":"🍯 Mulle meeldib mee maitse."},{"text":"🥶 Talvel magan ma pikka und."},{"text":"💪 Ma olen suur ja tugev."}],"options":[{"label":"Hunt","isCorrect":false},{"label":"Karu","isCorrect":true},{"label":"Põder","isCorrect":false}],"additionalData":{"backgroundColor":"0xFFDDA0DD","category":"animal","icon":"🐾"}},{"level":"5","type":"animal","question":"Ma elan külmas kohas ja mulle meeldib ujuda. Ma ei oska lennata, aga ma kõnnin naljakalt. Kes ma olen?","hints":[{"text":"❄️ Ma elan väga külmades kohtades, kus on jääd."},{"text":"🐟 Mulle meeldib vees kala püüda."},{"text":"🚶 Ma kõnnin maapinnal naljakalt, aga vees olen kiire."}],"options":[{"label":"Part","isCorrect":false},{"label":"Pingviin","isCorrect":true},{"label":"Kajakas","isCorrect":false}],"additionalData":{"backgroundColor":"0xFFFFD700","category":"animal","icon":"🐾"}}],"weather":[{"level":"1","type":"weather","question":"Mis on taevas kollane ja teeb kõik soojaks?","hints":[{"text":"👀 Sa näed mind taevas päeval."},{"text":"🔥 Ma teen maad soojaks."},{"text":"🔵 Ma olen suur ja ümmargune."}],"options":[{"label":"Kuu","isCorrect":false},{"label":"Päike","isCorrect":true},{"label":"Pilv","isCorrect":false}],"additionalData":{"backgroundColor":"0xFFADD8E6","category":"weather","icon":"🌤️"}},{"level":"2","type":"weather","question":"Mis langeb taevast alla tilkadena ja teeb maa märjaks?","hints":[{"text":"💧 Ma teen lompe."},{"text":"☔ Inimesed kasutavad minu eest vihmavarju."},{"text":"☁️ Ma tulen tihti tumedatest pilvedest."}],"options":[{"label":"Lumi","isCorrect":false},{"label":"Vihm","isCorrect":true},{"label":"Tuul","isCorrect":false}],"additionalData":{"backgroundColor":"0xFFB0C4DE","category":"weather","icon":"🌤️"}},{"level":"3","type":"weather","question":"Ma olen taevas hall või valge ja liigun aeglaselt. Mõnikord sajab minust alla. Mis ma olen?","hints":[{"text":"☁️ Ma olen valmistatud pisikestest veepiiskadest."},{"text":"🌬️ Tuul liigutab mind."},{"text":"☔ Minust võib tulla vihma või lund."}],"options":[{"label":"Päike","isCorrect":false},{"label":"Pilv","isCorrect":true},{"label":"Tuul","isCorrect":false}],"additionalData":{"backgroundColor":"0xFFD3D3D3","category":"weather","icon":"🌤️"}},{"level":"4","type":"weather","question":"Ma olen nähtamatu, aga tunned mind, kui puud lehvivad ja juuksed lendavad. Mis ma olen?","hints":[{"text":"🌬️ Ma saan asju liikuma panna."},{"text":"🍃 Ma panen lehed puu otsas tantsima."},{"text":"💨 Mind ei saa käes hoida."}],"options":[{"label":"Udu","isCorrect":false},{"label":"Tuul","isCorrect":true},{"label":"Külm","isCorrect":false}],"additionalData":{"backgroundColor":"0xFFB0E0E6","category":"weather","icon":"🌤️"}},{"level":"5","type":"weather","question":"Ma olen valge ja külm. Ma katan talvel maad ja minust saab teha lumememme. Mis ma olen?","hints":[{"text":"❄️ Ma langeb alla, kui on väga külm."},{"text":"🧤 Inimesed kannavad minu pärast kindaid ja mütsi."},{"text":"🔨 Minust saab ehitada lumememme."}],"options":[{"label":"Jää","isCorrect":false},{"label":"Lumi","isCorrect":true},{"label":"Vihm","isCorrect":false}],"additionalData":{"backgroundColor":"0xFFF0F8FF","category":"weather","icon":"🌤️"}}]}