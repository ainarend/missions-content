{"transport":[{"level":"1","type":"transport","question":"Mul on neli ratast ja ma sõidan teedel. Mind saab parkida garaaži. Kes ma olen?","hints":[{"text":"🛣️ Sõidan mööda asfalti."},{"text":"👨‍👩‍👧‍👦 Tihti sõidab minuga terve pere."},{"text":"🎨 Mind on palju erinevates värvides."}],"options":[{"label":"Ratas","isCorrect":false},{"label":"Auto","isCorrect":true},{"label":"Rong","isCorrect":false}],"additionalData":{"backgroundColor":"0xFF9370DB","category":"transport","icon":"🚦"}},{"level":"2","type":"transport","question":"Mul on tiivad, aga ma ei ole lind. Ma lendan taevas ja viin inimesi kaugele. Mis ma olen?","hints":[{"text":"☁️ Ma lendan pilvede kohal."},{"text":"🌍 Ma viin sind teise riiki."},{"text":"👂 Ma teen õhku tõustes valju häält."}],"options":[{"label":"Helikopter","isCorrect":false},{"label":"Lennuk","isCorrect":true},{"label":"Rakett","isCorrect":false}],"additionalData":{"backgroundColor":"0xFF9370DB","category":"transport","icon":"🚦"}},{"level":"3","type":"transport","question":"Mul on palju vaguneid ja ma sõidan raudteel. Ma teen \"tuut-tuut\" häält. Kes ma olen?","hints":[{"text":"🛤️ Minu jaoks on spetsiaalsed teed."},{"text":"💨 Ma teen vahel suitsu või auru."},{"text":"🏘️ Ma peatan jaamades."}],"options":[{"label":"Tramm","isCorrect":false},{"label":"Rong","isCorrect":true},{"label":"Buss","isCorrect":false}],"additionalData":{"backgroundColor":"0xFF9370DB","category":"transport","icon":"🚦"}},{"level":"4","type":"transport","question":"Ma olen suur ja ujun vees. Ma viin inimesi või kaupa üle mere. Mis ma olen?","hints":[{"text":"🌊 Ma liigun mere peal."},{"text":"🗺️ Ma aitad reisida üle vee."},{"text":"🐦 Kajakad lendavad minu kohal."}],"options":[{"label":"Purjekas","isCorrect":false},{"label":"Laev","isCorrect":true},{"label":"Allveelaev","isCorrect":false}],"additionalData":{"backgroundColor":"0xFF9370DB","category":"transport","icon":"🚦"}},{"level":"5","type":"transport","question":"Mul on kaks ratast ja ma sõidan pedaalides. Mind ei pea tankima. Mis ma olen?","hints":[{"text":"🤸‍♂️ Minuga sõitmiseks on vaja tasakaalu."},{"text":"🔔 Mul on kell, millega saab \"tring-tring\" teha."},{"text":"🌳 Minuga saab minna parki või metsa."}],"options":[{"label":"Roller","isCorrect":false},{"label":"Jalgratas","isCorrect":true},{"label":"Mootorratas","isCorrect":false}],"additionalData":{"backgroundColor":"0xFF9370DB","category":"transport","icon":"🚦"}}],"plant":[{"level":"1","type":"plant","question":"Ma olen värviline ja lõhnav, ning mind armastavad mesilased ja inimesed.","hints":[{"text":"🤔 Mõtle millelegi, mis kasvab aias ja on ilus."},{"text":"💡 Mesilastele meeldib minu nektar."},{"text":"🎁 Mind kingitakse tihti erilistel puhkudel."}],"options":[{"label":"Puu","isCorrect":false},{"label":"Lill","isCorrect":true},{"label":"Kivi","isCorrect":false}],"additionalData":{"backgroundColor":"0xFF9370DB","category":"plant","icon":"🌱"}},{"level":"2","type":"plant","question":"Ma kasvan puu otsas, olen tihti punane või roheline ja mind on hea hammustada.","hints":[{"text":"⬆️ Mind saad puu otsast."},{"text":"😋 Mind on hea süüa vahepalaks."},{"text":"🤔 Mõnikord elab minus ussike."}],"options":[{"label":"Pirn","isCorrect":false},{"label":"Õun","isCorrect":true},{"label":"Kurg","isCorrect":false}],"additionalData":{"backgroundColor":"0xFF9370DB","category":"plant","icon":"🌱"}},{"level":"3","type":"plant","question":"Ma olen suur ja tugev, mul on paks koor ja palju lehti, ning ma pakun varju.","hints":[{"text":"📍 Mind on palju metsas."},{"text":"🤔 Minu okste vahel elavad oravad."},{"text":"⏳ Sügisel mu lehed kukuvad maha."}],"options":[{"label":"Põõsas","isCorrect":false},{"label":"Loom","isCorrect":false},{"label":"Puu","isCorrect":true}],"additionalData":{"backgroundColor":"0xFF9370DB","category":"plant","icon":"🌱"}},{"level":"4","type":"plant","question":"Ma kasvan maa sees, olen oranž ja mind meeldib küülikutele.","hints":[{"text":"🔊 Mind on hea krõmpsutada."},{"text":"👀 Ma olen hea su silmadele."},{"text":"🚜 Mind korjatakse põllult."}],"options":[{"label":"Kartul","isCorrect":false},{"label":"Porgand","isCorrect":true},{"label":"Kapsas","isCorrect":false}],"additionalData":{"backgroundColor":"0xFF9370DB","category":"plant","icon":"🌱"}},{"level":"5","type":"plant","question":"Ma olen maa all peidus, hoian taime püsti ja aitan tal juua vett.","hints":[{"text":"🌍 Sa ei näe mind tavaliselt."},{"text":"💡 Ma joon taimedele vett."},{"text":"💪 Ma olen nagu taime ankur."}],"options":[{"label":"Vars","isCorrect":false},{"label":"Juured","isCorrect":true},{"label":"Leht","isCorrect":false}],"additionalData":{"backgroundColor":"0xFF9370DB","category":"plant","icon":"🌱"}}]}