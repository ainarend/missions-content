{"ocean":[{"level":"1","type":"ocean","question":"Ma olen suur ja sinine, aga mind saab ka juua. Mis ma olen?","hints":[{"text":"🤔 Mõtle, mis on mere sees."},{"text":"👀 Ma olen läbipaistev ja märg."},{"text":"💡 Ilma minuta polekski merd."}],"options":[{"label":"Liiv","isCorrect":false},{"label":"Vesi","isCorrect":true},{"label":"Kivi","isCorrect":false}],"additionalData":{"backgroundColor":"0xFF4682B4","category":"ocean","icon":"🌊"}},{"level":"2","type":"ocean","question":"Ma olen pisikesi terakesi täis ja minu peal saab mängida. Mis ma olen?","hints":[{"text":"📍 Sa leiad mind mere äärest."},{"text":"👣 Minu peal on tore käia ja torne ehitada."},{"text":"🟡 Ma olen tihti kollakas või hall."}],"options":[{"label":"Muld","isCorrect":false},{"label":"Liiv","isCorrect":true},{"label":"Kivi","isCorrect":false}],"additionalData":{"backgroundColor":"0xFF8FBC8F","category":"ocean","icon":"🌊"}},{"level":"3","type":"ocean","question":"Ma ujun vee peal ja viin inimesi kaugele maale. Mis ma olen?","hints":[{"text":"💨 Mul on tihti suured purjed või mootor."},{"text":"🏘️ Minu koduks on sadam."},{"text":"🌍 Ma aitan sul ületada suuri veekogusid."}],"options":[{"label":"Lennuk","isCorrect":false},{"label":"Laev","isCorrect":true},{"label":"Auto","isCorrect":false}],"additionalData":{"backgroundColor":"0xFFADD8E6","category":"ocean","icon":"🌊"}},{"level":"4","type":"ocean","question":"Ma tõusen ja langen, toon merekõhinat kaldale. Mis ma olen?","hints":[{"text":"🌬️ Mind liigutab tuul."},{"text":"🤸‍♀️ Minu peal saab surfata."},{"text":"↔️ Ma liigun mööda mere pinda."}],"options":[{"label":"Pilv","isCorrect":false},{"label":"Laine","isCorrect":true},{"label":"Vihm","isCorrect":false}],"additionalData":{"backgroundColor":"0xFF6A5ACD","category":"ocean","icon":"🌊"}},{"level":"5","type":"ocean","question":"Ma seisan kaljude peal ja näitan meremeestele teed pimedas. Mis ma olen?","hints":[{"text":"💡 Minul on suur ja ere tuli."},{"text":"🗼 Ma olen kõrge ehitis mere ääres."},{"text":"🚧 Ma hoia