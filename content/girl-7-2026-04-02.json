{"plant":[{"level":"1","type":"plant","question":"Ma olen väike ja kõva. Ma magan mulla sees ja ootan, et sind näeks. Kui mind kasta, ärkan ellu. Kes ma olen?","hints":[{"text":"🤔 Mõtle mille seest taim kasvama hakkab."},{"text":"💧 Mulle meeldib vesi ja soe päike."},{"text":"🤏 Ma olen sageli väga pisike."}],"options":[{"label":"Lill","isCorrect":false},{"label":"Seeme","isCorrect":true},{"label":"Kivi","isCorrect":false}],"additionalData":{"backgroundColor":"0xFFA5D6A7","category":"plant","icon":"🌱"}},{"level":"2","type":"plant","question":"Ma olen sageli roheline ja istun oksa küljes. Ma püüan päikest ja teen taimele toitu. Kes ma olen?","hints":[{"text":"👀 Sa näed mind puudel ja põõsastel."},{"text":"💚 Ma olen enamasti roheline."},{"text":"🌬️ Sügisel langevad mu sõbrad maapinnale."}],"options":[{"label":"Okas","isCorrect":false},{"label":"Leht","isCorrect":true},{"label":"Koor","isCorrect":false}],"additionalData":{"backgroundColor":"0xFFA5D6A7","category":"plant","icon":"🌱"}},{"level":"3","type":"plant","question":"Ma avan end kevadel ja suvel, et näidata oma värve. Mul on kroonlehed ja ma lõhnan magusalt. Kes ma olen?","hints":[{"text":"🎨 Mul on palju erinevaid värve."},{"text":"👃 Mõnikord ma lõhnan väga hästi."},{"text":"🐝 Minu juurde tulevad tihti mesilased."}],"options":[{"label":"Mari","isCorrect":false},{"label":"Lill","isCorrect":true},{"label":"Käbi","isCorrect":false}],"additionalData":{"backgroundColor":"0xFFA5D6A7","category":"plant","icon":"🌱"}},{"level":"4","type":"plant","question":"Ma kasvan maa all oranžiks ja krõmpsuks. Jänesed armastavad mind ja ma olen silmadele hea. Kes ma olen?","hints":[{"text":"🐰 Jänesed armastavad mind väga."},{"text":"🔶 Ma olen tavaliselt säravoranž."},{"text":"🌍 Ma kasvan mulla sees."}],"options":[{"label":"Kartul","isCorrect":false},{"label":"Porgand","isCorrect":true},{"label":"Redis","isCorrect":false}],"additionalData":{"backgroundColor":"0xFFA5D6A7","category":"plant","icon":"🌱"}},{"level":"5","type":"plant","question":"Ma olen suur ja tugev. Mul on oksad ja lehed. Ma annan varju ja puhast õhku. Kes ma olen?","hints":[{"text":"⬆️ Ma olen tavaliselt väga pikk."},{"text":"🏡 Linnud ehitavad minu okstele pesi."},{"text":"🌬️ Ma aitan õhku värskendada."}],"options":[{"label":"Põõsas","isCorrect":false},{"label":"Puu","isCorrect":true},{"label":"Kaktus","isCorrect":false}],"additionalData":{"backgroundColor":"0xFFA5D6A7","category":"plant","icon":"🌱"}}],"weather":[{"level":"1","type":"weather","question":"Mis annab meile valgust ja sooja ning ilmub taevasse ainult päeval?","hints":[{"text":"💡 Annan valgust ja soojust."},{"text":"✨ Mind on hea tunda, kui on külm."},{"text":"🌍 Minu ümber pöörleb meie planeet."}],"options":[{"label":"Päike","isCorrect":true},{"label":"Kuu","isCorrect":false},{"label":"Pilv","isCorrect":false}],"additionalData":{"backgroundColor":"0xFF87CEEB","category":"weather","icon":"🌤️"}},{"level":"2","type":"weather","question":"Ma tulen pilvedest alla ja teen maa märjaks. Mis ma olen?","hints":[{"text":"💧 Kukun pilvedest alla."},{"text":"💦 Teen kõik märjaks."},{"text":"🌳 Taimed vajavad mind kasvamiseks."}],"options":[{"label":"Vihm","isCorrect":true},{"label":"Lumi","isCorrect":false},{"label":"Tuul","isCorrect":false}],"additionalData":{"backgroundColor":"0xFF87CEEB","category":"weather","icon":"🌤️"}},{"level":"3","type":"weather","question":"Mul on seitse värvi ja ma ilmuma taevasse pärast vihma, kui Päike jälle paistab. Kes ma olen?","hints":[{"text":"🎨 Olen väga värviline."},{"text":"🤩 Ilmun peale vihma, kui Päike jälle paistab."},{"text":"🌟 Olen suur kaar taevas."}],"options":[{"label":"Udu","isCorrect":false},{"label":"Pilv","isCorrect":false},{"label":"Vikerkaar","isCorrect":true}],"additionalData":{"backgroundColor":"0xFF87CEEB","category":"weather","icon":"🌤️"}},{"level":"4","type":"weather","question":"Mind ei näe, aga tunned. Ma liigutan lehti ja lennutan lohesid. Mis ma olen?","hints":[{"text":"🌿 Panen puude lehed sahisema."},{"text":"🪁 Aitan lohesid lennutada."},{"text":"🏞️ Ma värskendan õhku."}],"options":[{"label":"Tuul","isCorrect":true},{"label":"Udu","isCorrect":false},{"label":"Lumi","isCorrect":false}],"additionalData":{"backgroundColor":"0xFF87CEEB","category":"weather","icon":"🌤️"}},{"level":"5","type":"weather","question":"Ma olen valge ja külm. Katan talvel maad ja minust saab lumememme ehitada. Mis ma olen?","hints":[{"text":"⚪ Katan talvel maad valge vaibaga."},{"text":"🎿 Minuga saab mäest alla sõita."},{"text":"❄️ Muudan maastiku ilusaks."}],"options":[{"label":"Jää","isCorrect":false},{"label":"Lumi","isCorrect":true},{"label":"Raud","isCorrect":false}],"additionalData":{"backgroundColor":"0xFF87CEEB","category":"weather","icon":"🌤️"}}]}