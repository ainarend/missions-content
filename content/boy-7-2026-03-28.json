{"animal":[{"level":"1","type":"animal","question":"Ma olen väike ja kiire. Mulle meeldib juust. Kes ma olen?","hints":[{"text":"🧀 Mulle meeldib piimatooted."},{"text":"💨 Olen tihti peidus seinte vahel."},{"text":"💡 Minu nimi algab H-tähega ja lõpeb R-tähega."}],"options":[{"label":"Siil","isCorrect":false},{"label":"Konn","isCorrect":false},{"label":"Hiir","isCorrect":true}],"additionalData":{"backgroundColor":"0xFF9370DB","category":"animal","icon":"🐾"}},{"level":"2","type":"animal","question":"Ma hüppan ja elan vee lähedal. Teen krooks-krooks häält. Kes ma olen?","hints":[{"text":"💧 Mulle meeldib märjad kohad."},{"text":"🦵 Mul on pikad ja tugevad jalad hüppamiseks."},{"text":"📢 Suvel kuuled mind tiigist krooksumas."}],"options":[{"label":"Part","isCorrect":false},{"label":"Konn","isCorrect":true},{"label":"Karu","isCorrect":false}],"additionalData":{"backgroundColor":"0xFF9370DB","category":"animal","icon":"🐾"}},{"level":"3","type":"animal","question":"Mul on punakas karv ja kohev saba. Olen kaval metsloom. Kes ma olen?","hints":[{"text":"🌲 Elan metsas."},{"text":"👀 Minu silmad on sageli kollased."},{"text":"🤫 Olen öösel jahti pidamas, kui kõik magavad."}],"options":[{"label":"Jänes","isCorrect":false},{"label":"Rebane","isCorrect":true},{"label":"Orav","isCorrect":false}],"additionalData":{"backgroundColor":"0xFF9370DB","category":"animal","icon":"🐾"}},{"level":"4","type":"animal","question":"Ma lendan öösel vaikselt ja mul on suured silmad. Oskan pead peaaegu ringi keerata. Kes ma olen?","hints":[{"text":"🌙 Olen aktiivne pimedas."},{"text":"🗣️ Mu hääl on \"uhu-uhu\"."},{"text":"🌳 Puhkust veedan puude otsas."}],"options":[{"label":"Kotkas","isCorrect":false},{"label":"Nahkhiir","isCorrect":false},{"label":"Öökull","isCorrect":true}],"additionalData":{"backgroundColor":"0xFF9370DB","category":"animal","icon":"🐾"}},{"level":"5","type":"animal","question":"Ma näen välja nagu hobune, aga mul on mustvalged triibud. Elan kaugel Aafrikas. Kes ma olen?","hints":[{"text":"🎨 Mu kasukas on justkui vöötidega."},{"text":"🌍 Kohtad mind savannis."},{"text":"🐎 Kuulun hobuslaste perekonda."}],"options":[{"label":"Hobune","isCorrect":false},{"label":"Tiiger","isCorrect":false},{"label":"Sebra","isCorrect":true}],"additionalData":{"backgroundColor":"0xFF9370DB","category":"animal","icon":"🐾"}}]}